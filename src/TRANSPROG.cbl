       IDENTIFICATION DIVISION.
       PROGRAM-ID. TRANSPROG.
       AUTHOR. GEMINI-CLI.

       DATA DIVISION.
       WORKING-STORAGE SECTION.
           COPY "LOG-DATA.cpy" REPLACING LK-LOG-DATA BY WS-LOG-DATA.
           COPY "FIN-DATA.cpy" REPLACING FIN-DATA BY WS-FIN-DATA.
           
       01  WS-INTERNAL-STATE.
           05  WS-TRANS-COUNT      PIC 9(05) VALUE 0.
           05  WS-ERROR-FLAG       PIC X(01) VALUE 'N'.

       LINKAGE SECTION.
           COPY "TRANS-REC.cpy".

       PROCEDURE DIVISION USING TRANS-REC.

       MAIN-LOGIC SECTION.
       000-START.
           MOVE "INFO " TO WS-LOG-LEVEL.
           MOVE "TRANSPROG" TO WS-LOG-SENDER.
           MOVE "PROCESSING TRANSACTION " TO WS-LOG-MSG.
           STRING WS-LOG-MSG TRANS-ID INTO WS-LOG-MSG.
           CALL "LOGGER" USING WS-LOG-DATA.

           PERFORM 100-VALIDATE-TRANS.
           
           IF WS-ERROR-FLAG = 'N'
               PERFORM 200-CALCULATE-FINANCE
           END-IF.

           IF WS-ERROR-FLAG = 'N'
               SET TRANS-POSTED TO TRUE
               MOVE "INFO " TO WS-LOG-LEVEL
               MOVE "TRANSACTION POSTED SUCCESSFULLY" TO WS-LOG-MSG
               CALL "LOGGER" USING WS-LOG-DATA
           ELSE
               SET TRANS-FAILED TO TRUE
               MOVE "ERROR" TO WS-LOG-LEVEL
               MOVE "TRANSACTION FAILED" TO WS-LOG-MSG
               CALL "LOGGER" USING WS-LOG-DATA
           END-IF.

           GOBACK.

       100-VALIDATE-TRANS.
           IF TRANS-AMOUNT <= 0
               MOVE 'Y' TO WS-ERROR-FLAG
               DISPLAY "ERROR: INVALID TRANSACTION AMOUNT " TRANS-AMOUNT
           END-IF.
           
           IF TRANS-DATE = 0
               MOVE 'Y' TO WS-ERROR-FLAG
               DISPLAY "ERROR: MISSING TRANSACTION DATE"
           END-IF.

       200-CALCULATE-FINANCE.
           MOVE TRANS-AMOUNT TO FIN-AMOUNT OF WS-FIN-DATA.
           CALL "FINPROG" USING WS-FIN-DATA.
           
           IF FIN-STATUS OF WS-FIN-DATA NOT = "00"
               MOVE 'Y' TO WS-ERROR-FLAG
               DISPLAY "ERROR: FINANCIAL CALCULATION FAILED"
           ELSE
               MOVE FIN-TOTAL OF WS-FIN-DATA TO TRANS-AMOUNT
               DISPLAY "FINAL AMOUNT AFTER TAX/DISC: " TRANS-AMOUNT
           END-IF.
